<Window x:Class="ScriptLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:md="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        Title="Script Launcher"
        Width="420"
        Height="300"
        ResizeMode="CanResize"
        SizeToContent="Height"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Admin = light yellow background, Normal = transparent -->
        <Style x:Key="AdminAwareButtonStyle"
               BasedOn="{StaticResource MaterialDesignFlatButton}"
               TargetType="Button">
            <Style.Triggers>
                <DataTrigger Binding="{Binding RunAsAdministrator}"
                             Value="True">
                    <Setter Property="Background"
                            Value="#FFF9C4" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RunAsAdministrator}"
                             Value="False">
                    <Setter Property="Background"
                            Value="Transparent" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Left-side blue bar: insert BEFORE this card -->
        <Style x:Key="DropIndicatorLeft"
               TargetType="Border">
            <Setter Property="BorderBrush"
                    Value="#1976D2" />
            <Setter Property="BorderThickness"
                    Value="3,0,0,0" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="IsHitTestVisible"
                    Value="False" />
        </Style>

        <!-- Right-side blue bar: insert AFTER this card -->
        <Style x:Key="DropIndicatorRight"
               TargetType="Border">
            <Setter Property="BorderBrush"
                    Value="#1976D2" />
            <Setter Property="BorderThickness"
                    Value="0,0,3,0" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="IsHitTestVisible"
                    Value="False" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="4">
        <ListBox x:Name="CommandListBox"
                 ItemsSource="{Binding Commands}"
                 Background="Transparent"
                 BorderThickness="0"
                 AllowDrop="True"
                 PreviewMouseLeftButtonDown="ListBox_PreviewMouseLeftButtonDown"
                 PreviewMouseMove="ListBox_PreviewMouseMove"
                 DragOver="ListBox_DragOver"
                 DragLeave="ListBox_DragLeave"
                 Drop="ListBox_Drop">

            <ListBox.ContextMenu>
                <ContextMenu Style="{StaticResource MaterialDesignContextMenu}"
                             TextElement.FontSize="12">
                    <MenuItem Header="➕ Add New"
                              Command="{Binding OpenAddWindowCommand}" />
                </ContextMenu>
            </ListBox.ContextMenu>

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding"
                            Value="0" />
                    <Setter Property="Margin"
                            Value="2" />
                    <Setter Property="Background"
                            Value="Transparent" />
                    <Setter Property="BorderThickness"
                            Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <!--
                                    Grid lets the drop-indicator Border sit
                                    on top of the card without displacing it.
                                -->
                                <Grid>
                                    <ContentPresenter />
                                    <Border x:Name="DropIndicator"
                                            Visibility="Collapsed"
                                            Style="{StaticResource DropIndicatorLeft}"
                                            Width="76"
                                            Height="76" />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <materialDesign:Card Width="76"
                                         Height="76"
                                         Padding="0"
                                         UniformCornerRadius="4">
                        <Button Command="{Binding ExecuteCommand}"
                                ToolTip="{Binding Description}"
                                Style="{StaticResource AdminAwareButtonStyle}"
                                Width="76"
                                Height="76"
                                Padding="0">

                            <Button.ContextMenu>
                                <ContextMenu Style="{StaticResource MaterialDesignContextMenu}"
                                             TextElement.FontSize="12">
                                    <MenuItem Header="✏️  Edit"
                                              Command="{Binding EditCommand}" />
                                    <MenuItem Header="🗑️  Delete"
                                              Command="{Binding DeleteCommand}" />
                                </ContextMenu>
                            </Button.ContextMenu>

                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <md:PackIcon Kind="{Binding IconKind}"
                                             Width="30"
                                             Height="30"
                                             HorizontalAlignment="Center"
                                             Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                <TextBlock Text="{Binding Name}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           MaxWidth="70"
                                           Margin="0 4 0 0"
                                           FontSize="10"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}" />
                            </StackPanel>
                        </Button>
                    </materialDesign:Card>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </ScrollViewer>
</Window>