<Window x:Class="ScriptLauncher.Views.CommandEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        xmlns:conv="clr-namespace:ScriptLauncher.Converters"
        Title="{Binding WindowTitle}"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </Window.Resources>

    <StackPanel Margin="20">

        <!-- Icon picker row -->
        <DockPanel Margin="0 0 0 12">

            <!-- Preview the selected icon -->
            <Border Width="52"
                    Height="52"
                    CornerRadius="4"
                    Background="{DynamicResource MaterialDesignChipBackground}"
                    DockPanel.Dock="Left"
                    Margin="0 0 12 0">
                <md:PackIcon Kind="{Binding PreviewIconKind}"
                             Width="30"
                             Height="30"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource PrimaryHueMidBrush}" />
            </Border>

            <TextBox md:HintAssist.Hint="Icon name  (e.g. FolderOpen, RocketLaunch)"
                     Text="{Binding IconText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     VerticalAlignment="Center" />
        </DockPanel>

        <TextBox md:HintAssist.Hint="Name *"
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0 0 0 10" />

        <TextBox md:HintAssist.Hint="Description"
                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0 0 0 10" />

        <!-- Type combo -->
        <ComboBox md:HintAssist.Hint="Type"
                  ItemsSource="{Binding Types}"
                  SelectedItem="{Binding SelectedType}"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  Margin="0 0 0 10" />

        <TextBox md:HintAssist.Hint="Command *"
                 Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="60"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0 0 0 10" />

        <TextBox md:HintAssist.Hint="Arguments"
                 Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0 0 0 10" />

        <TextBox md:HintAssist.Hint="Working Directory"
                 Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0 0 0 10" />

        <!-- Checkboxes -->
        <StackPanel Orientation="Horizontal"
                    Margin="0 0 0 16">
            <CheckBox Content="Run as Administrator"
                      IsChecked="{Binding RunAsAdministrator}"
                      Margin="0 0 24 0" />
            <CheckBox Content="Open Window"
                      IsChecked="{Binding OpenWindow}" />
        </StackPanel>

        <TextBlock Text="{Binding ValidationMessage}"
                   Foreground="Red"
                   FontSize="11"
                   Margin="0 0 0 8"
                   Visibility="{Binding ValidationMessage,
               Converter={StaticResource NullToVisibilityConverter}}" />

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="CANCEL"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Margin="0 0 8 0" />

            <Button Content="SAVE"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding SaveCommand}"
                    IsDefault="True" />
        </StackPanel>

    </StackPanel>
</Window>